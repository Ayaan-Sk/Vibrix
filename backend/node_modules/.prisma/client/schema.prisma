datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id             String                  @id @default(auto()) @map("_id") @db.ObjectId
  name           String
  email          String                  @unique
  passwordHash   String                  @map("password_hash")
  role           Role                    @default(student)
  department     String
  avatarUrl      String?                 @map("avatar_url")
  isActive       Boolean                 @default(true) @map("is_active")
  createdAt      DateTime                @default(now()) @map("created_at")
  updatedAt      DateTime                @updatedAt @map("updated_at")
  notices        Notice[]
  readLaters     ReadLater[]
  dismissals     NotificationDismissal[]
  calendarEvents CalendarEvent[]

  @@map("users")
}

enum Role {
  admin
  faculty
  student
}

model Notice {
  id                    String                  @id @default(auto()) @map("_id") @db.ObjectId
  title                 String
  content               String?
  summary               String?
  importantDates        Json?                   @map("important_dates")
  originalImageUrl      String?                 @map("original_image_url")
  extractedText         String?                 @map("extracted_text")
  detectedLanguage      String?                 @map("detected_language")
  department            String                  @default("ALL")
  urgency               Urgency                 @default(normal)
  tags                  Json?
  isPinned              Boolean                 @default(false) @map("is_pinned")
  isDraft               Boolean                 @default(false) @map("is_draft")
  isStartupNotification Boolean                 @default(false) @map("is_startup_notification")
  expiryDate            DateTime?               @map("expiry_date")
  postedById            String                  @map("posted_by") @db.ObjectId
  postedBy              User                    @relation(fields: [postedById], references: [id])
  calendarEvents        CalendarEvent[]
  readLaters            ReadLater[]
  dismissals            NotificationDismissal[]
  createdAt             DateTime                @default(now()) @map("created_at")
  updatedAt             DateTime                @updatedAt @map("updated_at")

  @@map("notices")
}

enum Urgency {
  critical
  normal
  low
}

model ReadLater {
  id       String    @id @default(auto()) @map("_id") @db.ObjectId
  userId   String    @map("user_id") @db.ObjectId
  noticeId String    @map("notice_id") @db.ObjectId
  savedAt  DateTime  @default(now()) @map("saved_at")
  isRead   Boolean   @default(false) @map("is_read")
  readAt   DateTime? @map("read_at")
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  notice   Notice    @relation(fields: [noticeId], references: [id], onDelete: Cascade)

  @@unique([userId, noticeId])
  @@map("read_later")
}

model NotificationDismissal {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  userId      String   @map("user_id") @db.ObjectId
  noticeId    String   @map("notice_id") @db.ObjectId
  dismissedAt DateTime @default(now()) @map("dismissed_at")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  notice      Notice   @relation(fields: [noticeId], references: [id], onDelete: Cascade)

  @@unique([userId, noticeId])
  @@map("notification_dismissals")
}

model CalendarEvent {
  id             String    @id @default(auto()) @map("_id") @db.ObjectId
  title          String
  startDate      DateTime  @map("start_date")
  endDate        DateTime? @map("end_date")
  type           EventType @default(other)
  department     String    @default("ALL")
  linkedNoticeId String?   @map("linked_notice_id") @db.ObjectId
  linkedNotice   Notice?   @relation(fields: [linkedNoticeId], references: [id])
  createdById    String    @map("created_by") @db.ObjectId
  createdBy      User      @relation(fields: [createdById], references: [id])
  createdAt      DateTime  @default(now()) @map("created_at")

  @@map("calendar_events")
}

enum EventType {
  exam
  event
  holiday
  deadline
  placement
  other
}
